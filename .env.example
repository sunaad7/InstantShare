# Optional local configuration.
# The server uses PORT when supplied; otherwise it listens on port 3000.
PORT=3000
# Optional TURN relay. Set these in production to support viewers behind
# restrictive NATs/firewalls where direct WebRTC cannot connect.
NEXT_PUBLIC_TURN_URL=turn:your-turn-server.example.com:3478
NEXT_PUBLIC_TURN_USERNAME=your-username
NEXT_PUBLIC_TURN_CREDENTIAL=your-credential
